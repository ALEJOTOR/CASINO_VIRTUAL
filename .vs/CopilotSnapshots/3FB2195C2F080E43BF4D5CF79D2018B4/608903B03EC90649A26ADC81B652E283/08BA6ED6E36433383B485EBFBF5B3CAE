using DAL;
using ENTITY;

namespace BLL
{
    /// <summary>
    /// Crea los archivos de datos iniciales si no existen.
    /// Se llama una sola vez al arrancar la aplicación (Program.cs).
    /// </summary>
    public class InicializadorServicio
    {
        public void InicializarTodo()
        {
            InicializarEstadosUsuario();
            InicializarRoles();
            InicializarJuegos();
            InicializarEstadosPartida();
            new UsuarioServicio().InicializarAdmin();
        }

        private void InicializarEstadosUsuario()
        {
            EstadoUsuarioRepositorio repo = new EstadoUsuarioRepositorio();
            if (repo.Consultar().Count > 0) return;

            repo.Guardar(new EstadoUsuario { IdEstado = 1, Nombre = "activo", Descripcion = "Usuario activo en el sistema" });
            repo.Guardar(new EstadoUsuario { IdEstado = 2, Nombre = "inactivo", Descripcion = "Usuario inactivo" });
            repo.Guardar(new EstadoUsuario { IdEstado = 3, Nombre = "suspendido", Descripcion = "Usuario suspendido" });
        }

        private void InicializarRoles()
        {
            RolRepositorio repo = new RolRepositorio();
            if (repo.Consultar().Count > 0) return;

            repo.Guardar(new Rol { IdRol = 1, NombreRol = "administrador", Descripcion = "Acceso total al sistema" });
            repo.Guardar(new Rol { IdRol = 2, NombreRol = "cliente", Descripcion = "Acceso a juegos y saldo" });
        }

        private void InicializarJuegos()
        {
            JuegoRepositorio repo = new JuegoRepositorio();
            if (repo.Consultar().Count > 0) return;

            repo.Guardar(new Juego { IdJuego = 1, Nombre = "Minas", Descripcion = "Juego tipo minas con apuestas", Estado = "activo" });
        }

        private void InicializarEstadosPartida()
        {
            EstadoPartidaRepositorio repo = new EstadoPartidaRepositorio();
            if (repo.Consultar().Count > 0) return;

            repo.Guardar(new EstadoPartida { IdEstado = 1, NombreEstado = "en curso", Descripcion = "Partida activa" });
            repo.Guardar(new EstadoPartida { IdEstado = 2, NombreEstado = "ganada", Descripcion = "El usuario ganó" });
            repo.Guardar(new EstadoPartida { IdEstado = 3, NombreEstado = "perdida", Descripcion = "El usuario perdió" });
            repo.Guardar(new EstadoPartida { IdEstado = 4, NombreEstado = "cancelada", Descripcion = "Partida cancelada" });
        }
    }
}
