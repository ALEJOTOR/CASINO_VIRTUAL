<UserControl x:Class="GUI.Views.UcPerfil"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPrincipalBrush}">
    <ScrollViewer>
        <StackPanel Margin="24">
            <TextBlock Text="Mi Perfil"
                       Style="{StaticResource TitleStyle}" />
            <TextBlock Text="Información de tu cuenta"
                       Style="{StaticResource SubtitleStyle}"
                       Margin="0,4,0,20" />

            <Border Style="{StaticResource CardStyle}" MaxWidth="500">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="80" Height="80"
                                CornerRadius="40"
                                Background="{StaticResource BgElevatedBrush}"
                                Margin="0,0,20,0">
                            <TextBlock Text="👤"
                                       FontSize="36"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding NombreCompleto}"
                                       Foreground="{StaticResource DoradoBrush}"
                                       FontSize="20" FontWeight="Bold" />
                            <TextBlock Text="{Binding Username}"
                                       Foreground="{StaticResource TextoSecundarioBrush}"
                                       FontSize="13" />
                        </StackPanel>
                    </Grid>

                    <Separator Background="{StaticResource BordeBrush}"
                               Margin="0,0,0,16" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Identificación:"
                                   Foreground="{StaticResource TextoSecundarioBrush}"
                                   FontWeight="Bold" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Identificacion}"
                                   Foreground="{StaticResource TextoPrimarioBrush}"
                                   Margin="0,0,0,10" />

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Correo:"
                                   Foreground="{StaticResource TextoSecundarioBrush}"
                                   FontWeight="Bold" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding Correo}"
                                   Foreground="{StaticResource TextoPrimarioBrush}"
                                   Margin="0,0,0,10" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Saldo:"
                                   Foreground="{StaticResource TextoSecundarioBrush}"
                                   FontWeight="Bold" Margin="0,0,0,10" />
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding SaldoTexto}"
                                   Foreground="{StaticResource VerdeBrush}"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10" />

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="Registro:"
                                   Foreground="{StaticResource TextoSecundarioBrush}"
                                   FontWeight="Bold" />
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding FechaRegistro}"
                                   Foreground="{StaticResource TextoPrimarioBrush}" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
