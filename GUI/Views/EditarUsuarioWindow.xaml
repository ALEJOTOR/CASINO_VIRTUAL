<Window x:Class="GUI.Views.EditarUsuarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GUI.ViewModels"
        Title="{Binding IdValor, StringFormat='Editando: {0}'}"
        Width="520" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgPrincipalBrush}">
    <Window.DataContext>
        <vm:EditarUsuarioViewModel />
    </Window.DataContext>

    <Border Background="{StaticResource BgCardBrush}"
            CornerRadius="10"
            BorderBrush="{StaticResource BordeBrush}"
            BorderThickness="1"
            Margin="20">
        <ScrollViewer>
            <StackPanel Margin="16">
                <TextBlock Text="Editar Usuario"
                           Style="{StaticResource TitleStyle}"
                           FontSize="20"
                           Margin="0,0,0,16" />

                <TextBlock Text="ID:" Foreground="{StaticResource TextoSecundarioBrush}" FontWeight="Bold" />
                <TextBlock Text="{Binding IdValor}" Margin="0,0,0,8"
                           Foreground="{StaticResource TextoPrimarioBrush}" />

                <TextBlock Text="Usuario:" Foreground="{StaticResource TextoSecundarioBrush}" FontWeight="Bold" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                <TextBlock Text="Contraseña (dejar vacío para no cambiar):"
                           Foreground="{StaticResource TextoSecundarioBrush}" FontWeight="Bold" />
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Primer nombre:" Foreground="{StaticResource TextoSecundarioBrush}" FontWeight="Bold" />
                        <TextBox Text="{Binding Nombre1, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Segundo nombre:" Foreground="{StaticResource TextoSecundarioBrush}" FontWeight="Bold" />
                        <TextBox Text="{Binding Nombre2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Primer apellido:" Foreground="{StaticResource TextoSecundarioBrush}" FontWeight="Bold" />
                        <TextBox Text="{Binding Apellido1, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Segundo apellido:" Foreground="{StaticResource TextoSecundarioBrush}" FontWeight="Bold" />
                        <TextBox Text="{Binding Apellido2, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Correo:" Foreground="{StaticResource TextoSecundarioBrush}" FontWeight="Bold" />
                <TextBox Text="{Binding Correo, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Fecha de nacimiento:" Foreground="{StaticResource TextoSecundarioBrush}" FontWeight="Bold" />
                        <DatePicker SelectedDate="{Binding FechaNacimiento}"
                                    Background="{StaticResource BgInputBrush}"
                                    Foreground="{StaticResource TextoPrimarioBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Estado:" Foreground="{StaticResource TextoSecundarioBrush}" FontWeight="Bold" />
                        <ComboBox SelectedItem="{Binding Estado}"
                                  ItemsSource="{Binding Estados}"
                                  Background="{StaticResource BgInputBrush}"
                                  Foreground="{StaticResource TextoPrimarioBrush}" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource RojoBrush}"
                           FontSize="12"
                           Margin="0,12,0,0" />

                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Guardar"
                            Command="{Binding GuardarCommand}"
                            Style="{StaticResource SuccessButtonStyle}" />
                    <Button Grid.Column="2" Content="Cancelar"
                            Command="{Binding CancelarCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Background="{StaticResource BgHoverBrush}"
                            Foreground="{StaticResource TextoPrimarioBrush}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
