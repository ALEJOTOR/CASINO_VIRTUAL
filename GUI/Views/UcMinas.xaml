<UserControl x:Class="GUI.Views.UcMinas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GUI.Converters"
             Background="#0D1117">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#070C18">
            <TextBlock Text="MINAS ROYAL"
                       FontFamily="Georgia"
                       FontSize="22" FontWeight="Bold"
                       Foreground="Gold"
                       Margin="22,0,0,0"
                       VerticalAlignment="Center" />
        </Border>

        <Grid Grid.Row="1" Margin="28,26,28,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="320" MaxWidth="400" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#121B27"
                    CornerRadius="14"
                    BorderBrush="#405469"
                    BorderThickness="1"
                    Padding="20,24"
                    Margin="0,0,20,0">
                <StackPanel>
                    <TextBlock Text="Apuesta ($)"
                               Foreground="#CBD5E1"
                               FontSize="10" FontWeight="Bold"
                               Margin="0,0,0,4" />
                    <WrapPanel Margin="0,0,0,12">
                        <Button Content="-"
                                Width="48" Height="42"
                                FontSize="16" FontWeight="Bold"
                                Foreground="#F1F5F9"
                                Background="#121B2A"
                                BorderBrush="#2C3E52"
                                BorderThickness="1"
                                Cursor="Hand"
                                Command="{Binding AjustarApuestaCommand}"
                                CommandParameter="-1" />
                        <TextBox Text="{Binding ApuestaTexto, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="140" Height="42"
                                 FontSize="12" FontWeight="Bold"
                                 TextAlignment="Center"
                                 IsEnabled="{Binding ApuestaControlsEnabled}"
                                 Margin="6,0" />
                        <Button Content="+"
                                Width="48" Height="42"
                                FontSize="16" FontWeight="Bold"
                                Foreground="#F1F5F9"
                                Background="#121B2A"
                                BorderBrush="#2C3E52"
                                BorderThickness="1"
                                Cursor="Hand"
                                Command="{Binding AjustarApuestaCommand}"
                                CommandParameter="1" />
                    </WrapPanel>

                    <TextBlock Text="Número de minas"
                               Foreground="#CBD5E1"
                               FontSize="10" FontWeight="Bold"
                               Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding BotonesMinas}"
                                  Margin="0,0,0,12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Texto}"
                                        Margin="0,0,6,6"
                                        MinWidth="66" Height="38"
                                        FontSize="10" FontWeight="Bold"
                                        Cursor="Hand"
                                        IsEnabled="{Binding Permitido}"
                                        Command="{Binding DataContext.SeleccionarMinasCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                        CommandParameter="{Binding Valor}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#121B2A" />
                                            <Setter Property="Foreground" Value="#F1F5F9" />
                                            <Setter Property="BorderBrush" Value="#2C3E52" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Activo}" Value="True">
                                                    <Setter Property="Background" Value="#22C55E" />
                                                    <Setter Property="Foreground" Value="#07120D" />
                                                    <Setter Property="BorderBrush" Value="#86EFAC" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Permitido}" Value="False">
                                                    <Setter Property="Background" Value="#0F172A" />
                                                    <Setter Property="Foreground" Value="#94A3B8" />
                                                    <Setter Property="BorderBrush" Value="#1E293B" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Tamaño de cuadrícula"
                               Foreground="#CBD5E1"
                               FontSize="10" FontWeight="Bold"
                               Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding BotonesCuadricula}"
                                  Margin="0,0,0,20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Texto}"
                                        Margin="0,0,6,6"
                                        MinWidth="62" Height="38"
                                        FontSize="10" FontWeight="Bold"
                                        Cursor="Hand"
                                        Command="{Binding DataContext.SeleccionarCuadriculaCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                        CommandParameter="{Binding Valor}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#121B2A" />
                                            <Setter Property="Foreground" Value="#F1F5F9" />
                                            <Setter Property="BorderBrush" Value="#2C3E52" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Activo}" Value="True">
                                                    <Setter Property="Background" Value="#22C55E" />
                                                    <Setter Property="Foreground" Value="#07120D" />
                                                    <Setter Property="BorderBrush" Value="#86EFAC" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="{Binding BotonAccionTexto}"
                            Command="{Binding AccionPrincipalCommand}"
                            Height="52"
                            FontSize="12" FontWeight="Bold"
                            Cursor="Hand"
                            Margin="0,0,0,12"
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#22C55E" />
                                <Setter Property="Foreground" Value="#07120D" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PartidaActiva}" Value="True">
                                        <Setter Property="Background" Value="#FBBF24" />
                                        <Setter Property="Foreground" Value="#0F152A" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBlock Text="{Binding MultiplicadorTexto}"
                               Foreground="#FBBF24"
                               FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,8" />

                    <TextBlock Text="{Binding EstadoTexto}"
                               Foreground="#F1F5F9"
                               FontSize="11" FontWeight="Bold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />

                    <TextBlock Text="{Binding SaldoTexto}"
                               Foreground="#FBBF24"
                               FontSize="13" FontWeight="Bold" />
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Próximos multiplicadores"
                               Foreground="#CBD5E1"
                               FontSize="10" FontWeight="Bold"
                               Margin="0,0,0,6" />
                    <ItemsControl ItemsSource="{Binding Multiplicadores}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6"
                                        Padding="12,8"
                                        Margin="0,0,8,0"
                                        Height="34">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#142030" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EsSiguiente}" Value="True">
                                                    <Setter Property="Background" Value="#FBBF24" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Texto}"
                                               FontSize="10" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#F1F5F9" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EsSiguiente}" Value="True">
                                                        <Setter Property="Foreground" Value="#111827" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Border Grid.Row="1"
                        Background="#0D1117"
                        CornerRadius="18"
                        BorderBrush="#30748F"
                        BorderThickness="3"
                        Padding="18">
                    <Viewbox Stretch="Uniform">
                        <Grid x:Name="BoardGrid" />
                    </Viewbox>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.RowSpan="2"
                Background="#80000000"
                Visibility="{Binding DialogoPersonalVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="#121B27"
                    CornerRadius="12"
                    BorderBrush="#2C3E52"
                    BorderThickness="1"
                    Width="320" Height="160"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Margin="20">
                    <TextBlock Text="Minas personalizadas"
                               Foreground="#F1F5F9"
                               FontSize="14" FontWeight="Bold"
                               Margin="0,0,0,12" />
                    <TextBox Text="{Binding DialogoPersonalInput, UpdateSourceTrigger=PropertyChanged}"
                             Height="36"
                             FontSize="12" FontWeight="Bold"
                             TextAlignment="Center"
                             Margin="0,0,0,16" />
                    <WrapPanel HorizontalAlignment="Center">
                        <Button Content="Aceptar"
                                Width="100" Height="36"
                                FontSize="10" FontWeight="Bold"
                                Background="#22C55E"
                                Foreground="#07120D"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,12,0"
                                Command="{Binding AceptarDialogoPersonalCommand}" />
                        <Button Content="Cancelar"
                                Width="100" Height="36"
                                FontSize="10" FontWeight="Bold"
                                Background="#1E293B"
                                Foreground="#F1F5F9"
                                BorderThickness="0"
                                Cursor="Hand"
                                Command="{Binding CancelarDialogoPersonalCommand}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
