<UserControl x:Class="GUI.Views.UcTransacciones"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GUI.Converters"
             Background="{StaticResource BgPrincipalBrush}">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:TipoToColorConverter x:Key="TipoToColorConverter" />
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Transacciones del Sistema" Style="{StaticResource TitleStyle}" />
            <TextBlock Text="{Binding InfoPaginacion, StringFormat='Total de transacciones: {0}'}"
                       Style="{StaticResource SubtitleStyle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Filtros" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8" />
                <WrapPanel Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="Desde:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <DatePicker SelectedDate="{Binding FechaDesde, Mode=TwoWay}" Width="130" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="Hasta:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <DatePicker SelectedDate="{Binding FechaHasta, Mode=TwoWay}" Width="130" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="Tipo:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <ComboBox ItemsSource="{Binding Tipos}"
                                  SelectedItem="{Binding TipoSeleccionado}"
                                  Width="130" />
                    </StackPanel>
                    <Button Content="Aplicar Filtro" Command="{Binding AplicarFiltroCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" />
                    <Button Content="Limpiar" Command="{Binding LimpiarFiltroCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <WrapPanel Grid.Row="2" Margin="0,0,0,12">
            <Border Style="{StaticResource CardStyle}" Width="180" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Depósitos" Foreground="{StaticResource TextoSecundarioBrush}" FontSize="11" />
                    <TextBlock Text="{Binding TotalDepositos, StringFormat='${0:N2}'}"
                               Foreground="{StaticResource VerdeBrush}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Width="180" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Retiros" Foreground="{StaticResource TextoSecundarioBrush}" FontSize="11" />
                    <TextBlock Text="{Binding TotalRetiros, StringFormat='${0:N2}'}"
                               Foreground="{StaticResource RojoBrush}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Width="180" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Balance Neto" Foreground="{StaticResource TextoSecundarioBrush}" FontSize="11" />
                    <TextBlock Text="{Binding BalanceNeto, StringFormat='${0:N2}'}"
                               Foreground="{StaticResource DoradoBrush}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Width="180">
                <StackPanel>
                    <TextBlock Text="Bonos Aplicados" Foreground="{StaticResource TextoSecundarioBrush}" FontSize="11" />
                    <TextBlock Text="{Binding TotalBonos, StringFormat='${0:N2}'}"
                               Foreground="{StaticResource VioletaBrush}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
        </WrapPanel>

        <DataGrid Grid.Row="3" ItemsSource="{Binding TransaccionesPaginadas}"
                  IsReadOnly="True" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding IdTransaccion}" Width="70" />
                <DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="180" />
                <DataGridTemplateColumn Header="Tipo" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2"
                                    Background="{Binding Tipo, Converter={StaticResource TipoToColorConverter}}"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Tipo}" FontWeight="SemiBold"
                                           Foreground="White" FontSize="12" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Monto" Binding="{Binding Monto, StringFormat='${0:N2}'}" Width="130" />
                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat='dd/MM/yyyy HH:mm'}" Width="150" />
                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Margin="0,12,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding InfoPaginacion}"
                           Foreground="{StaticResource TextoSecundarioBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="|&lt;" Command="{Binding IrPrimeraCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="0,0,4,0" />
                    <Button Content="&lt;" Command="{Binding PaginaAnteriorCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="0,0,4,0" />
                    <Button Content="&gt;" Command="{Binding PaginaSiguienteCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="0,0,4,0" />
                    <Button Content="&gt;|" Command="{Binding IrUltimaCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.RowSpan="3"
                Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Cargando..." Foreground="{StaticResource DoradoBrush}"
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
