<Window x:Class="GUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GUI.ViewModels"
        xmlns:views="clr-namespace:GUI.Views"
        Title="Casino Royal"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrincipalBrush}">
    <Window.Resources>
        <!-- User View DataTemplates -->
        <DataTemplate DataType="{x:Type vm:InicioViewModel}">
            <views:UcInicio />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistorialViewModel}">
            <views:UcHistorial />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BilleteraViewModel}">
            <views:UcBilletera />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MisBonosViewModel}">
            <views:UcMisBonos />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SoporteViewModel}">
            <views:UcSoporte />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PerfilViewModel}">
            <views:UcPerfil />
        </DataTemplate>

        <!-- Game View DataTemplates -->
        <DataTemplate DataType="{x:Type vm:MinasViewModel}">
            <views:UcMinas />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RuletaViewModel}">
            <views:UcRuleta />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TragamonedasViewModel}">
            <views:UcTragamonedas />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Navbar -->
        <Border Grid.Row="0" Background="{StaticResource BgNavbarBrush}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <TextBlock Grid.Column="0"
                           Text="CASINO ROYAL"
                           FontFamily="Georgia"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource DoradoBrush}"
                           VerticalAlignment="Center" />

                <!-- Navigation -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="40,0,0,0"
                            VerticalAlignment="Center">
                    <Button Content="Inicio" Command="{Binding IrInicioCommand}"
                            Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Historial" Command="{Binding IrHistorialCommand}"
                            Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Billetera" Command="{Binding IrBilleteraCommand}"
                            Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Mis Bonos" Command="{Binding IrMisBonosCommand}"
                            Style="{StaticResource NavButtonStyle}" />
                    <Button Content="Soporte" Command="{Binding IrSoporteCommand}"
                            Style="{StaticResource NavButtonStyle}" />
                </StackPanel>

                <!-- Saldo + Cerrar sesión -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource BgCardBrush}"
                            CornerRadius="12"
                            BorderBrush="{StaticResource DoradoBrush}"
                            BorderThickness="1"
                            Padding="14,6"
                            Margin="0,0,12,0">
                        <TextBlock Text="{Binding SaldoTexto}"
                                   Foreground="{StaticResource DoradoBrush}"
                                   FontWeight="Bold"
                                   FontSize="13" />
                    </Border>
                    <Button Content="Cerrar sesión"
                            Command="{Binding CerrarSesionCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            FontSize="12"
                            Height="34" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentViewModel}"
                        Margin="0" />
    </Grid>
</Window>
