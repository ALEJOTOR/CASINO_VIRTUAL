<Window x:Class="GUI.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GUI.ViewModels"
        xmlns:views="clr-namespace:GUI.Views"
        Title="Casino Royal - Administración"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrincipalBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardAdminViewModel}">
            <views:UcDashboardAdmin />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GestionUsuariosViewModel}">
            <views:UcGestionUsuarios />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PartidasAdminViewModel}">
            <views:UcPartidas />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TransaccionesAdminViewModel}">
            <views:UcTransacciones />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdminGridViewModel}">
            <views:UcAdminGrid />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdminReportesViewModel}">
            <views:UcAdminReportes />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BitacoraViewModel}">
            <views:UcBitacora />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GestionBonosViewModel}">
            <views:UcGestionBonos />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GestionFinancieraViewModel}">
            <views:UcGestionFinanciera />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Navbar -->
        <Border Grid.Row="0" Background="{StaticResource BgNavbarBrush}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding NombreAdmin}"
                           FontFamily="Georgia"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource DoradoBrush}"
                           VerticalAlignment="Center" />

                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled" Margin="24,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Dashboard" Command="{Binding IrDashboardCommand}"
                                Style="{StaticResource NavButtonStyle}" />
                        <Button Content="Usuarios" Command="{Binding IrUsuariosCommand}"
                                Style="{StaticResource NavButtonStyle}" />
                        <Button Content="Partidas" Command="{Binding IrPartidasCommand}"
                                Style="{StaticResource NavButtonStyle}" />
                        <Button Content="Transacciones" Command="{Binding IrTransaccionesCommand}"
                                Style="{StaticResource NavButtonStyle}" />
                        <Button Content="Reportes" Command="{Binding IrReportesCommand}"
                                Style="{StaticResource NavButtonStyle}" />
                        <Button Content="Bitácora" Command="{Binding IrBitacoraCommand}"
                                Style="{StaticResource NavButtonStyle}" />
                        <Button Content="Bonos" Command="{Binding IrBonosCommand}"
                                Style="{StaticResource NavButtonStyle}" />
                        <Button Content="Gestión Financiera" Command="{Binding IrGestionFinancieraCommand}"
                                Style="{StaticResource NavButtonStyle}" />
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Column="2"
                        Content="Salir"
                        Command="{Binding CerrarSesionCommand}"
                        Style="{StaticResource DangerButtonStyle}"
                        FontSize="12"
                        Height="34" />
            </Grid>
        </Border>

        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentViewModel}"
                        Margin="0" />
    </Grid>
</Window>
