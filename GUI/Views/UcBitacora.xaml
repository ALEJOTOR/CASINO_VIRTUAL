<UserControl x:Class="GUI.Views.UcBitacora"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GUI.Converters"
             Background="{StaticResource BgPrincipalBrush}">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Bitácora del Sistema" Style="{StaticResource TitleStyle}" />
            <TextBlock Text="{Binding InfoPaginacion, StringFormat='Registro de eventos: {0}'}"
                       Style="{StaticResource SubtitleStyle}" Margin="0,4,0,8" />

            <WrapPanel>
                <Border CornerRadius="12" Padding="10,4" Background="#1A5E1A" Margin="0,0,8,0">
                    <TextBlock Foreground="#69F0AE" FontSize="12" FontWeight="Bold">
                        <Run Text="INFO" /><Run Text=": " /><Run Text="{Binding ContadorInfo}" />
                    </TextBlock>
                </Border>
                <Border CornerRadius="12" Padding="10,4" Background="#5E4F1A" Margin="0,0,8,0">
                    <TextBlock Foreground="#FFD54F" FontSize="12" FontWeight="Bold">
                        <Run Text="WARN" /><Run Text=": " /><Run Text="{Binding ContadorWarn}" />
                    </TextBlock>
                </Border>
                <Border CornerRadius="12" Padding="10,4" Background="#5E1A1A" Margin="0,0,8,0">
                    <TextBlock Foreground="#EF9A9A" FontSize="12" FontWeight="Bold">
                        <Run Text="ERROR" /><Run Text=": " /><Run Text="{Binding ContadorError}" />
                    </TextBlock>
                </Border>
                <Border CornerRadius="12" Padding="10,4" Background="#3E1A1A" Margin="0,0,8,0">
                    <TextBlock Foreground="#FFCDD2" FontSize="12" FontWeight="Bold">
                        <Run Text="CRITICAL" /><Run Text=": " /><Run Text="{Binding ContadorCritical}" />
                    </TextBlock>
                </Border>
            </WrapPanel>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Filtros" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8" />
                <WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="Desde:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <DatePicker SelectedDate="{Binding FechaDesde, Mode=TwoWay}" Width="120" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="Hasta:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <DatePicker SelectedDate="{Binding FechaHasta, Mode=TwoWay}" Width="120" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="Nivel:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <ComboBox ItemsSource="{Binding Niveles}"
                                  SelectedItem="{Binding NivelSeleccionado}" Width="110" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="Tipo:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <ComboBox ItemsSource="{Binding TiposEvento}"
                                  SelectedItem="{Binding TipoSeleccionado}" Width="150" />
                    </StackPanel>
                    <Button Content="Filtrar" Command="{Binding AplicarFiltroCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" />
                    <Button Content="Limpiar" Command="{Binding LimpiarFiltroCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="3" ItemsSource="{Binding EventosPaginados}"
                  IsReadOnly="True" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat='dd/MM/yyyy HH:mm:ss'}" Width="150" />
                <DataGridTemplateColumn Header="Nivel" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="8,2" HorizontalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource BgCardBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Nivel}" Value="INFO">
                                                <Setter Property="Background" Value="#1565C0" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Nivel}" Value="WARN">
                                                <Setter Property="Background" Value="#F9A825" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Nivel}" Value="ERROR">
                                                <Setter Property="Background" Value="#D32F2F" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Nivel}" Value="CRITICAL">
                                                <Setter Property="Background" Value="#B71C1C" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Nivel}" FontWeight="Bold"
                                           Foreground="White" FontSize="11" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Tipo Evento" Binding="{Binding TipoEvento}" Width="140" />
                <DataGridTextColumn Header="Módulo" Binding="{Binding Modulo}" Width="100" />
                <DataGridTextColumn Header="Usuario" Binding="{Binding Username}" Width="140" />
                <DataGridTextColumn Header="IP" Binding="{Binding IpOrigen}" Width="120" />
                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Margin="0,8,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding InfoPaginacion}"
                           Foreground="{StaticResource TextoSecundarioBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="|&lt;" Command="{Binding IrPrimeraCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="0,0,4,0" />
                    <Button Content="&lt;" Command="{Binding PaginaAnteriorCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="0,0,4,0" />
                    <Button Content="&gt;" Command="{Binding PaginaSiguienteCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="0,0,4,0" />
                    <Button Content="&gt;|" Command="{Binding IrUltimaCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.RowSpan="4"
                Background="#80000000"
                Visibility="{Binding IsCargando, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Cargando..." Foreground="{StaticResource DoradoBrush}"
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
