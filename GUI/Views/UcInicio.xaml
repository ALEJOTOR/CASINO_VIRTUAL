<UserControl x:Class="GUI.Views.UcInicio"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPrincipalBrush}">
    <ScrollViewer>
        <StackPanel Margin="28,24,28,24">
            <!-- Header -->
            <Border Background="{StaticResource BgCardBrush}"
                    CornerRadius="14"
                    BorderBrush="{StaticResource BordeBrush}"
                    BorderThickness="1"
                    Padding="28,24"
                    Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="{Binding Bienvenido}"
                               Style="{StaticResource TitleStyle}"
                               FontSize="28" />
                    <TextBlock Text="Elige tu juego favorito y empieza a ganar."
                               Style="{StaticResource SubtitleStyle}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <!-- Game Cards -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Minas Card -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Minas"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource DoradoBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12" />

                        <Border Grid.Row="1"
                                Background="#082F49"
                                CornerRadius="8"
                                Height="160"
                                Margin="0,0,0,12">
                            <TextBlock Text="💎"
                                       FontSize="64"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <Button Grid.Row="2"
                                Content="Jugar ahora"
                                Command="{Binding JugarMinasCommand}"
                                Style="{StaticResource SuccessButtonStyle}"
                                Height="40" />
                    </Grid>
                </Border>

                <!-- Ruleta Card -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Ruleta"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource DoradoBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12" />

                        <Border Grid.Row="1"
                                Background="#31124D"
                                CornerRadius="8"
                                Height="160"
                                Margin="0,0,0,12">
                            <TextBlock Text="🎡"
                                       FontSize="64"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <Button Grid.Row="2"
                                Content="Jugar ahora"
                                Command="{Binding JugarRuletaCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                Height="40" />
                    </Grid>
                </Border>

                <!-- Tragamonedas Card -->
                <Border Grid.Column="4" Style="{StaticResource CardStyle}"
                        Padding="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Tragamonedas"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource DoradoBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12" />

                        <Border Grid.Row="1"
                                Background="#22120C"
                                CornerRadius="8"
                                Height="160"
                                Margin="0,0,0,12">
                            <TextBlock Text="🎰"
                                       FontSize="64"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <Button Grid.Row="2"
                                Content="Jugar ahora"
                                Command="{Binding JugarTragamonedasCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Background="{StaticResource AzulBrush}"
                                Height="40" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Stats Bar -->
            <Border Background="{StaticResource BgNavbarBrush}"
                    CornerRadius="10"
                    Margin="0,24,0,0"
                    Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="3 juegos"
                                   Foreground="{StaticResource DoradoBrush}"
                                   FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Activos"
                                   Foreground="{StaticResource TextoSecundarioBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="Saldo"
                                   Foreground="{StaticResource DoradoBrush}"
                                   FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="En tiempo real"
                                   Foreground="{StaticResource TextoSecundarioBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="Movimientos"
                                   Foreground="{StaticResource DoradoBrush}"
                                   FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Organizados"
                                   Foreground="{StaticResource TextoSecundarioBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
