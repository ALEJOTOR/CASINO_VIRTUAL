<UserControl x:Class="GUI.Views.UcTragamonedas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GUI.Converters"
             Background="#050912">
    <UserControl.Resources>
        <conv:InvertBoolConverter x:Key="InvertBool" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="78" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#080C18">
            <Grid>
                <TextBlock Text="FORTUNE SPINS"
                           FontFamily="Georgia"
                           FontSize="25" FontWeight="Bold"
                           Foreground="Gold"
                           Margin="24,0,0,0"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding SaldoTexto}"
                           FontSize="13" FontWeight="Bold"
                           Foreground="#4ADE80"
                           Background="#121E34"
                           Padding="12,0"
                           Height="40"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,24,0"
                           LineHeight="40" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid HorizontalAlignment="Center" Margin="24,16,24,24">
                <Border Width="780" MinHeight="540"
                        CornerRadius="18"
                        BorderBrush="#FBBF24"
                        BorderThickness="6"
                        Padding="6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#0E275A" Offset="0" />
                                        <GradientStop Color="#070B1A" Offset="1" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#761515"
                                CornerRadius="16"
                                BorderBrush="#FBBF24"
                                BorderThickness="3"
                                Height="76"
                                Margin="84,18,84,0">
                            <TextBlock Text="{Binding JackpotTexto}"
                                       Foreground="Gold"
                                       FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Row="1"
                                   Text="2 iguales pagan x2  |  3 iguales pagan x8"
                                   Foreground="#F1F5F9"
                                   FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0" />

                        <Border Grid.Row="2"
                                Background="#080D1A"
                                CornerRadius="14"
                                BorderBrush="#FBBF24"
                                BorderThickness="5"
                                Height="180"
                                Margin="60,16,60,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#FBBF24"/>
                                    <Setter Property="BorderThickness" Value="5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HayGanancia}" Value="True">
                                            <Setter Property="BorderBrush" Value="#22C55E"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#22C55E" BlurRadius="20" ShadowDepth="0"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Rectangle Grid.Column="0" Width="3"
                                           HorizontalAlignment="Right"
                                           Fill="#FBBF24" Opacity="0.5" />
                                <Rectangle Grid.Column="1" Width="3"
                                           HorizontalAlignment="Right"
                                           Fill="#FBBF24" Opacity="0.5" />

                                <Border x:Name="BorderRollo1"
                                        Grid.Column="0"
                                        Background="#0A1628"
                                        CornerRadius="12"
                                        Margin="16,12,8,12"
                                        BorderBrush="#FBBF24"
                                        BorderThickness="1">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="ScaleRollo1" ScaleX="1" ScaleY="1"
                                                        CenterX="90" CenterY="75"/>
                                    </Border.RenderTransform>
                                    <TextBlock Text="{Binding Rollo1}"
                                               FontFamily="Segoe UI Emoji"
                                               FontSize="56"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <Border x:Name="BorderRollo2"
                                        Grid.Column="1"
                                        Background="#0A1628"
                                        CornerRadius="12"
                                        Margin="8,12"
                                        BorderBrush="#FBBF24"
                                        BorderThickness="1">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="ScaleRollo2" ScaleX="1" ScaleY="1"
                                                        CenterX="90" CenterY="75"/>
                                    </Border.RenderTransform>
                                    <TextBlock Text="{Binding Rollo2}"
                                               FontFamily="Segoe UI Emoji"
                                               FontSize="56"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <Border x:Name="BorderRollo3"
                                        Grid.Column="2"
                                        Background="#0A1628"
                                        CornerRadius="12"
                                        Margin="8,12,16,12"
                                        BorderBrush="#FBBF24"
                                        BorderThickness="1">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="ScaleRollo3" ScaleX="1" ScaleY="1"
                                                        CenterX="90" CenterY="75"/>
                                    </Border.RenderTransform>
                                    <TextBlock Text="{Binding Rollo3}"
                                               FontFamily="Segoe UI Emoji"
                                               FontSize="56"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3" Margin="60,20,60,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Apuesta ($)"
                                           Foreground="#F1F5F9"
                                           FontSize="11" FontWeight="Bold"
                                           Margin="0,0,0,4" />
                                <TextBox Text="{Binding ApuestaTexto, UpdateSourceTrigger=PropertyChanged}"
                                         Height="48"
                                         FontSize="15" FontWeight="Bold"
                                         TextAlignment="Center"
                                         Background="#0A1628"
                                         Foreground="White"
                                         BorderBrush="#FBBF24"
                                         BorderThickness="2"
                                         VerticalContentAlignment="Center" />
                            </StackPanel>

                            <WrapPanel Grid.Column="1" Margin="16,8,16,0">
                                <Button Content="500" Width="82" Height="36"
                                        FontSize="10" FontWeight="Bold"
                                        Foreground="White" Background="#112240"
                                        BorderBrush="#EAB308" BorderThickness="1"
                                        Cursor="Hand" Margin="0,0,6,6"
                                        Command="{Binding ApuestaRapidaCommand}"
                                        CommandParameter="500" />
                                <Button Content="1K" Width="82" Height="36"
                                        FontSize="10" FontWeight="Bold"
                                        Foreground="White" Background="#112240"
                                        BorderBrush="#EAB308" BorderThickness="1"
                                        Cursor="Hand" Margin="0,0,6,6"
                                        Command="{Binding ApuestaRapidaCommand}"
                                        CommandParameter="1000" />
                                <Button Content="2.5K" Width="82" Height="36"
                                        FontSize="10" FontWeight="Bold"
                                        Foreground="White" Background="#112240"
                                        BorderBrush="#EAB308" BorderThickness="1"
                                        Cursor="Hand" Margin="0,0,6,6"
                                        Command="{Binding ApuestaRapidaCommand}"
                                        CommandParameter="2500" />
                                <Button Content="5K" Width="82" Height="36"
                                        FontSize="10" FontWeight="Bold"
                                        Foreground="White" Background="#112240"
                                        BorderBrush="#EAB308" BorderThickness="1"
                                        Cursor="Hand" Margin="0,0,6,6"
                                        Command="{Binding ApuestaRapidaCommand}"
                                        CommandParameter="5000" />
                                <Button Content="10K" Width="82" Height="36"
                                        FontSize="10" FontWeight="Bold"
                                        Foreground="White" Background="#112240"
                                        BorderBrush="#EAB308" BorderThickness="1"
                                        Cursor="Hand" Margin="0,0,6,6"
                                        Command="{Binding ApuestaRapidaCommand}"
                                        CommandParameter="10000" />
                                <Button Content="25K" Width="82" Height="36"
                                        FontSize="10" FontWeight="Bold"
                                        Foreground="White" Background="#112240"
                                        BorderBrush="#EAB308" BorderThickness="1"
                                        Cursor="Hand" Margin="0,0,0,6"
                                        Command="{Binding ApuestaRapidaCommand}"
                                        CommandParameter="25000" />
                            </WrapPanel>

                            <Border Grid.Column="2"
                                    Width="70" Height="70"
                                    VerticalAlignment="Center">
                                <Button Command="{Binding GirarCommand}"
                                        IsEnabled="{Binding Girando, Converter={StaticResource InvertBool}}"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#F59E0B"
                                                    CornerRadius="35"
                                                    BorderBrush="#78350F"
                                                    BorderThickness="3"
                                                    Width="70" Height="70">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                                <Setter Property="Background" Value="#D97706"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="GIRAR"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="#111827"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="4" Margin="60,0,60,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#F59E0B"
                                    CornerRadius="12"
                                    BorderBrush="#78350F"
                                    BorderThickness="2"
                                    Height="54" Width="170">
                                <TextBlock Text="APUESTA"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="#111827"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <Border Grid.Column="1"
                                    Background="#0F172A"
                                    CornerRadius="12"
                                    Height="54"
                                    Margin="22,0,0,0"
                                    BorderBrush="#FBBF24"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding ResultadoTexto}"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#FBBF24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </Grid>

                        <!-- Panel de estadísticas — Grid.Row="5" -->
                        <Border Grid.Row="5"
                                Background="#080D1A"
                                CornerRadius="12"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                Margin="60,0,60,20"
                                Padding="20,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Jugadas -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="JUGADAS"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#64748B"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding JugadasTexto}"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#F1F5F9"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Racha -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="RACHA"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#64748B"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RachaTexto}"
                                               FontSize="22" FontWeight="Bold"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#F1F5F9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RachaTexto[0]}" Value="+">
                                                        <Setter Property="Foreground" Value="#22C55E"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RachaTexto[0]}" Value="-">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Mayor ganancia -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="MEJOR JUGADA"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#64748B"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding MayorGananciaTexto}"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#FBBF24"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
