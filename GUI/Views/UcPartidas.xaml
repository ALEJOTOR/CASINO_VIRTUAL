<UserControl x:Class="GUI.Views.UcPartidas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GUI.Converters"
             Background="{StaticResource BgPrincipalBrush}">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:MontoToColorConverter x:Key="MontoToColorConverter" />
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Partidas del Sistema" Style="{StaticResource TitleStyle}" />
            <TextBlock Text="{Binding InfoPaginacion, StringFormat='Total de partidas en el sistema: {0}'}"
                       Style="{StaticResource SubtitleStyle}" />
        </StackPanel>

        <!-- Row 1: Filter Panel -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Filtros" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,8" />
                <WrapPanel Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="Desde:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <DatePicker SelectedDate="{Binding FechaDesde, Mode=TwoWay}" Width="130" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="Hasta:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <DatePicker SelectedDate="{Binding FechaHasta, Mode=TwoWay}" Width="130" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="Juego:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <ComboBox ItemsSource="{Binding Juegos}"
                                  SelectedValue="{Binding JuegoSeleccionado}"
                                  DisplayMemberPath="Nombre"
                                  SelectedValuePath="IdJuego"
                                  Width="140" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="Resultado:" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <ComboBox ItemsSource="{Binding Resultados}"
                                  SelectedItem="{Binding ResultadoSeleccionado}"
                                  Width="120" />
                    </StackPanel>
                    <Button Content="Aplicar Filtro" Command="{Binding AplicarFiltroCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" />
                    <Button Content="Limpiar" Command="{Binding LimpiarFiltroCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Row 2: Stats Cards -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,12">
            <Border Style="{StaticResource CardStyle}" Width="180" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Partidas" Foreground="{StaticResource TextoSecundarioBrush}" FontSize="11" />
                    <TextBlock Text="{Binding TotalPartidasFiltro, StringFormat='{}{0:N0}'}"
                               Foreground="{StaticResource DoradoBrush}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Width="140" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Ganadas" Foreground="{StaticResource TextoSecundarioBrush}" FontSize="11" />
                    <TextBlock Text="{Binding TotalGanadasFiltro, StringFormat='{}{0:N0}'}"
                               Foreground="{StaticResource VerdeBrush}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Width="140" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Perdidas" Foreground="{StaticResource TextoSecundarioBrush}" FontSize="11" />
                    <TextBlock Text="{Binding TotalPerdidasFiltro, StringFormat='{}{0:N0}'}"
                               Foreground="{StaticResource RojoBrush}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Width="180" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Apostado" Foreground="{StaticResource TextoSecundarioBrush}" FontSize="11" />
                    <TextBlock Text="{Binding TotalApostadoFiltro, StringFormat='${0:N2}'}"
                               Foreground="{StaticResource DoradoBrush}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Width="180">
                <StackPanel>
                    <TextBlock Text="Total Ganancias" Foreground="{StaticResource TextoSecundarioBrush}" FontSize="11" />
                    <TextBlock Text="{Binding TotalGananciaFiltro, StringFormat='${0:N2}'}"
                               Foreground="{StaticResource DoradoBrush}" FontSize="22" FontWeight="Bold" />
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Row 3: DataGrid -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding PartidasPaginadas}"
                  IsReadOnly="True" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding IdPartida}" Width="70" />
                <DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="180" />
                <DataGridTextColumn Header="Juego" Binding="{Binding Juego}" Width="140" />
                <DataGridTemplateColumn Header="Estado" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2"
                                    HorizontalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource BgCardBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Estado}" Value="ganada">
                                                <Setter Property="Background" Value="{StaticResource VerdeBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Estado}" Value="perdida">
                                                <Setter Property="Background" Value="{StaticResource RojoBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Estado}" FontWeight="SemiBold"
                                           Foreground="White" FontSize="12" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat='dd/MM/yyyy HH:mm'}" Width="150" />
                <DataGridTextColumn Header="Apuesta" Binding="{Binding Apuesta, StringFormat='${0:N2}'}" Width="120" />
                <DataGridTextColumn Header="Ganancia" Binding="{Binding Ganancia, StringFormat='${0:N2}'}" Width="120" />
                <DataGridTemplateColumn Header="Neta" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding GananciaNeta, StringFormat='${0:N2}'}"
                                       FontWeight="Bold"
                                       Foreground="{Binding GananciaNeta, Converter={StaticResource MontoToColorConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 4: Pagination -->
        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Margin="0,12,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding InfoPaginacion}"
                           Foreground="{StaticResource TextoSecundarioBrush}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="|&lt;" Command="{Binding IrPrimeraCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="0,0,4,0"
                            IsEnabled="{Binding HayPaginaAnterior}" />
                    <Button Content="&lt;" Command="{Binding PaginaAnteriorCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="0,0,4,0"
                            IsEnabled="{Binding HayPaginaAnterior}" />
                    <Button Content="&gt;" Command="{Binding PaginaSiguienteCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="0,0,4,0"
                            IsEnabled="{Binding HayPaginaSiguiente}" />
                    <Button Content="&gt;|" Command="{Binding IrUltimaCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Padding="8,4"
                            IsEnabled="{Binding HayPaginaSiguiente}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Border Grid.Row="2" Grid.RowSpan="3"
                Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Cargando..." Foreground="{StaticResource DoradoBrush}"
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
